# App
APP_ENV=local
PYTHONPATH=/app

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=retentionops
MLFLOW_BACKEND_STORE_URI=sqlite:////app/mlflow.db
MLFLOW_ARTIFACT_ROOT=file:///app/mlruns

# Model Registry
UPLIFT_MODEL_NAME=uplift_model
UPLIFT_MODEL_ALIAS=champion

# PostgreSQL
POSTGRES_USER=retentionops
POSTGRES_PASSWORD=retentionops
POSTGRES_DB=retentionops
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://retentionops:retentionops@postgres:5432/retentionops

# API
API_HOST=0.0.0.0
API_PORT=8000
ENABLE_DECISION_LOGGING=true

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin